{
  "doctype": "DocType",
  "name": "AlphaX POS Card Transaction",
  "module": "AlphaX POS Suite",
  "custom": 0,
  "is_table": 0,
  "editable_grid": 0,
  "autoname": "naming_series:",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "label": "Series",
      "fieldtype": "Select",
      "options": "ACT-.YYYY.-",
      "default": "ACT-.YYYY.-",
      "reqd": 1
    },
    {
      "fieldname": "transaction_uuid",
      "label": "Transaction UUID",
      "fieldtype": "Data",
      "unique": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Idempotency key for async card transactions. Generated by the cashier when initiating; matched on callback."
    },
    {
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Pending\nApproved\nDeclined\nError\nTimeout\nCancelled",
      "default": "Pending",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "vendor",
      "label": "Card Reader Vendor",
      "fieldtype": "Select",
      "options": "Geidea\nNetwork International\nPayTabs\nTap\nCheckout.com\nOther",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "card_reader",
      "label": "Card Reader",
      "fieldtype": "Link",
      "options": "AlphaX POS Card Reader",
      "description": "The configured card reader this transaction was sent to."
    },

    {
      "fieldname": "section_amount",
      "label": "Amount",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "amount",
      "label": "Amount",
      "fieldtype": "Currency",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "currency",
      "label": "Currency",
      "fieldtype": "Link",
      "options": "Currency"
    },
    {
      "fieldname": "is_refund",
      "label": "Is Refund",
      "fieldtype": "Check",
      "default": 0
    },
    {
      "fieldname": "original_transaction",
      "label": "Original Transaction (for refunds)",
      "fieldtype": "Link",
      "options": "AlphaX POS Card Transaction"
    },

    {
      "fieldname": "section_links",
      "label": "Related Documents",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "sales_invoice",
      "label": "Sales Invoice",
      "fieldtype": "Link",
      "options": "Sales Invoice",
      "in_list_view": 1
    },
    {
      "fieldname": "pos_order",
      "label": "POS Order",
      "fieldtype": "Link",
      "options": "AlphaX POS Order"
    },
    {
      "fieldname": "mode_of_payment",
      "label": "Mode of Payment",
      "fieldtype": "Link",
      "options": "Mode of Payment"
    },

    {
      "fieldname": "section_card",
      "label": "Card Details",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "auth_code",
      "label": "Auth Code",
      "fieldtype": "Data"
    },
    {
      "fieldname": "rrn",
      "label": "RRN",
      "fieldtype": "Data",
      "in_list_view": 1
    },
    {
      "fieldname": "trace_no",
      "label": "Trace/Stan",
      "fieldtype": "Data"
    },
    {
      "fieldname": "batch_no",
      "label": "Batch No",
      "fieldtype": "Data"
    },
    {
      "fieldname": "col_card_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "card_brand",
      "label": "Card/Tender Brand",
      "fieldtype": "Data"
    },
    {
      "fieldname": "masked_pan",
      "label": "Masked PAN (Last4)",
      "fieldtype": "Data"
    },
    {
      "fieldname": "terminal_id",
      "label": "Terminal ID (TID)",
      "fieldtype": "Data"
    },
    {
      "fieldname": "merchant_id",
      "label": "Merchant ID (MID)",
      "fieldtype": "Data"
    },

    {
      "fieldname": "section_timing",
      "label": "Timing & Response",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "requested_at",
      "label": "Requested At",
      "fieldtype": "Datetime",
      "read_only": 1
    },
    {
      "fieldname": "responded_at",
      "label": "Responded At",
      "fieldtype": "Datetime",
      "read_only": 1
    },
    {
      "fieldname": "duration_ms",
      "label": "Duration (ms)",
      "fieldtype": "Int",
      "read_only": 1,
      "description": "Round-trip from request to response, in milliseconds. Useful for monitoring terminal health."
    },
    {
      "fieldname": "col_timing_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "response_code",
      "label": "Response Code",
      "fieldtype": "Data"
    },
    {
      "fieldname": "response_message",
      "label": "Response Message",
      "fieldtype": "Small Text"
    },
    {
      "fieldname": "raw_response",
      "label": "Raw Response (JSON)",
      "fieldtype": "Code",
      "options": "JSON",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Accounts Manager",
      "read": 1
    },
    {
      "role": "AlphaX POS Manager",
      "read": 1
    },
    {
      "role": "AlphaX POS Supervisor",
      "read": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "description": "Audit log of every card-terminal transaction (approved, declined, timed out, error). Append-only by design; transactions are never edited after the response is recorded. UUID field provides idempotency for async flows."
}